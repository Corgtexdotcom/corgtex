DATABASE_URL="postgresql://postgres:postgres@localhost:5432/corgtex?schema=public"
APP_URL="http://localhost:3000"
NEXT_PUBLIC_APP_URL="http://localhost:3000"
NEXT_PUBLIC_SITE_URL="http://localhost:3001"
NEXT_PUBLIC_DEMO_URL=""
NEXT_PUBLIC_BOOK_DEMO_URL="https://calendly.com/corgtex/demo"

ADMIN_EMAIL="admin@example.com"
ADMIN_PASSWORD="change-me-now"
SEED_RESET_PASSWORDS="false"
WORKSPACE_NAME="Corgtex"
WORKSPACE_SLUG="corgtex"

SESSION_COOKIE_SECRET="replace-with-a-long-random-secret"

# Bootstrap agent auth for Phases 1-2.
AGENT_API_KEY=""
AGENT_ALLOWED_WORKSPACE_IDS=""

# Active agent browser credentials for frontend E2E tests
AGENT_E2E_EMAIL="system+corgtex@corgtex.local"
AGENT_E2E_PASSWORD="corgtex-test-agent-pw"

# Hosted model configuration.
MODEL_PROVIDER="openrouter"
MODEL_API_KEY=""
MODEL_BASE_URL="https://openrouter.ai/api/v1"
MODEL_CHAT_DEFAULT="google/gemma-4-31b-it"
MODEL_EMBEDDING_DEFAULT="google/gemini-embedding-001"
AGENT_KILL_SWITCH="false"
WORKSPACE_AGENT_MAX_CONCURRENCY="4"

# Cloudflare R2 Storage (S3-compatible)
R2_ACCOUNT_ID=""
R2_BUCKET_NAME="corgtex"
R2_ACCESS_KEY_ID=""
R2_SECRET_ACCESS_KEY=""
