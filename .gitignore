# dependencies
/node_modules
**/node_modules

# next.js
/.next/
**/.next/
/out/
*.tsbuildinfo

# local env files — NEVER commit secrets
.env
.env.*
!.env.example

# backup files that may contain secrets
*.bak
*.backup
*.orig
*.old
*.save
*.tmp

# secret/credential files
*.key
*.secret
*.credentials

# docs
.mintlify/
docs/assets/
docs/pr-assets/
docs/plans/
docs/partner-analysis/
docs/*handover*.md
docs/client-readiness-*.md
docs/pilot-*.md
docs/future-work*.md
docs/industrial-*.md
docs/slack-app-manifest.yml

# local agent planning and generated artifacts
.agents/plans/
.artifacts/

# prisma
/prisma/dev.db
/prisma/dev.db-journal

# IDE
.cursor/
.vscode/
*.swp
*.swo

# test output
/test-results/

# iCloud conflict duplicates
* 2.*
* 2/

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
# local client deployment repos
deploy-*/

# Exclude sensitive / private client data
SEEDDATA/
.private-seeds/

# Block ALL client-specific seed scripts. Private client data MUST NOT be
# committed to this public repository. Use the generic seed-client-stable.mjs
# entrypoint and inject config via CLIENT_SEED_CONFIG_JSON env var.
scripts/seed-*-stable.mjs
!scripts/seed-client-stable.mjs
scripts/seed-*-brain.mjs

# Client readiness smoke output
.artifacts/
