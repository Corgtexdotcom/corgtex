{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "baseUrl": ".",
    "plugins": [
      {
        "name": "next"
      }
    ],
    "paths": {
      "@/*": ["./*"],
      "@corgtex/shared": ["../../packages/shared/src/index.ts"],
      "@corgtex/domain": ["../../packages/domain/src/index.ts"],
      "@corgtex/workflows": ["../../packages/workflows/src/index.ts"],
      "@corgtex/models": ["../../packages/models/src/index.ts"],
      "@corgtex/knowledge": ["../../packages/knowledge/src/index.ts"],
      "@corgtex/agents": ["../../packages/agents/src/index.ts"]
    }
  },
  "include": [
    "next-env.d.ts",
    "**/*.ts",
    "**/*.tsx",
    ".next/types/**/*.ts"
  ],
  "exclude": ["node_modules"]
}
